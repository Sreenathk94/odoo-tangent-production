<?xml version="1.0" encoding="UTF-8"?>
<!-- Template for the project dashboard -->
<templates id="template" xml:space="preserve">
    <t t-name="ProjectDashboard">
        <div class="container mt-4 vh-100 overflow-auto">
            <h2 class="text-center mb-4">Project Dashboard</h2>

            <!-- Summary Cards -->
            <div class="row text-center">
                <div class="col-md-4">
                    <div class="card text-white bg-primary mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Total Projects</h5>
                            <p class="card-text display-4" t-esc="state.total_projects"></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-white bg-success mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Active Projects</h5>
                            <p class="card-text display-4" t-esc="state.active_projects"></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-white bg-danger mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Completed Projects</h5>
                            <p class="card-text display-4" t-esc="state.completed_projects"></p>
                        </div>
                    </div>
                </div>
            </div>
            <hr/>
            <!-- Project Status Chart -->
           <div class="row">
    <!-- Left: Project Status Chart -->
    <div class="col-md-6">
        <canvas id="projectStatusChart" style="height: 450px; width: 100%;"></canvas>
    </div>

    <!-- Right: Project Time Chart -->
    <div class="col-md-6">
        <canvas id="projectTimeChart" style="height: 450px; width: 100%;"></canvas>
    </div>
</div>
<hr/>
            <!-- Filters -->
            <div class="row mb-3">
                <div class="col-md-3">
                   <select class="form-control" t-model="state.filter_status">
    <option value="">Status</option>
                       <t t-foreach="state.project_stages" t-as="stage" t-key="stage.is">
        <option t-att-value="stage.id" t-esc="stage.name"/>
    </t>
</select>

                </div>
                <div class="col-md-3">
                    <select class="form-control" t-model="state.filter_priority">
                        <option value="">Priority</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="date" class="form-control" t-model="state.filter_date"/>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" t-on-click="applyFilters">Apply Filters</button>
                </div>
            </div>

            <!-- Project List Table -->
            <table class="table table-striped table-bordered">
                <thead class="thead-dark">
                    <tr>
                        <th>Project Name</th>
                        <th>Status</th>
                        <th>Timesheet duration (HH:MM)</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="state.projects" t-as="project" t-key="project.id">
                        <tr>
                            <td t-esc="project.name"/>
                            <td t-esc="project.status"/>
                            <td t-esc="project.timesheet_duration"/>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>
    </t>
</templates>