<odoo>
    <record id="view_cumulative_attendance_wizard" model="ir.ui.view">
        <field name="name">cumulative.attendance.wizard.form</field>
        <field name="model">cumulative.attendance.wizard</field>
        <field name="arch" type="xml">
            <form string="Cumulative Attendance Import" create="false" edit="false">
                <group>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button string="Import" type="object" name="import_attendance_csv" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cumulative_attendance_wizard" model="ir.actions.act_window">
        <field name="name">Import Cumulative Attendance</field>
        <field name="res_model">cumulative.attendance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_cumulative_attendance_root" name="Cumulative Attendance" parent="hr_attendance.menu_hr_attendance_root" groups="hr.group_hr_manager" />
    <menuitem id="menu_cumulative_attendance_import" name="Import Attendance"
              parent="menu_cumulative_attendance_root"
              action="action_cumulative_attendance_wizard"/>
</odoo>
