<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="timesheet_table_inherit" inherit_id="hr_timesheet.timesheet_table">
        <!-- Add Employee Cost header after Description column -->
        <xpath expr="//thead/tr/th[span='Description']" position="after">
            <th class="text-end align-middle"><span>Employee Cost</span></th>
        </xpath>

        <!-- Add Employee Cost cell after Description cell in each row -->
        <xpath expr="//tbody/tr/td[span[@t-field='line.name']]" position="after">
            <td class="text-end align-middle">
                <t t-set="emp_cost" t-value="line.unit_amount * (line.employee_id.current_employee_cost or 0)"/>
                <span t-esc="emp_cost" t-options="{'widget': 'monetary', 'display_currency': company.currency_id}"/>
            </td>
        </xpath>

        <!-- Add Total Employee Cost after the total Hours/Days strong in the footer row -->
        <xpath expr="//tbody/tr[last()]/td/strong[last()]" position="after">
            <strong style="margin-left: 20px;">
                <span style="margin-right: 15px;">Total Employee Cost</span>
                <t t-set="total_emp_cost" t-value="sum(line.unit_amount * (line.employee_id.current_employee_cost or 0) for line in lines)"/>
                <span t-esc="total_emp_cost" t-options="{'widget': 'monetary', 'display_currency': company.currency_id}"/>
            </strong>
        </xpath>
    </template>
</odoo>