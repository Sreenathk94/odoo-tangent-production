<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard Form View -->
        <record id="hr_employee_cost_import_wizard_form" model="ir.ui.view">
            <field name="name">hr.employee.cost.import.wizard.form</field>
            <field name="model">hr.employee.cost.import.wizard</field>
            <field name="arch" type="xml">
                <form string="Import Employee Costs">
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="import_file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                    <footer>
                        <button name="action_import" type="object" string="Import" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Wizard Action -->
        <record id="hr_employee_cost_import_wizard_action" model="ir.actions.act_window">
            <field name="name">Import Employee Costs</field>
            <field name="res_model">hr.employee.cost.import.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="hr_employee_cost_import_wizard_form"/>
        </record>
    </data>
</odoo>