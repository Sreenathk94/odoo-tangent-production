<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_holidays.action_view_calendar_manager_approve" model="ir.actions.act_window.view">
        <field name="sequence" eval="-1"/>
        <field name="view_mode">calendar</field>
        <field name="view_id" eval="False"/>
        <field name="act_window_id" ref="hr_holidays.hr_leave_action_action_approve_department"/>
    </record>
    <record id="hr_leave_view_form_inherits_hr_leave_submit_report" model="ir.ui.view">
        <field name="name">hr.leave.view.form.inherits.hr_leave_submit_report</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('o_attachment_preview')]" position="replace">
            </xpath>
        </field>
    </record>
    <record id="hr_leave_view_form" model="ir.ui.view">
        <field name="name">hr.leave.form.inherit.restrict_approval</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_approve']" position="attributes">
                <attribute name="groups">!hr_leave_submit_report.group_hr_leave_restricted</attribute>
            </xpath>
            <xpath expr="//button[@name='action_validate']" position="attributes">
                <attribute name="groups">!hr_leave_submit_report.group_hr_leave_restricted</attribute>
            </xpath>
            <xpath expr="//button[@name='action_refuse']" position="attributes">
                <attribute name="groups">!hr_leave_submit_report.group_hr_leave_restricted</attribute>
            </xpath>
        </field>
    </record>
</odoo>