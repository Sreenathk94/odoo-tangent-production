<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Form view for the hr.leave.refuse.wizard model -->
    <record id="view_hr_leave_refuse_wizard_form" model="ir.ui.view">
        <field name="name">hr.leave.refuse.wizard.form</field>
        <field name="model">hr.leave.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Refuse Leave">
                <sheet>
                    <group>
                        <field name="refuse_reason"/>
                    </group>
                    <footer>
                        <!-- Confirm button triggers the action_confirm_refuse method in the wizard model -->
                        <button string="Confirm" type="object" name="action_confirm_refuse" class="btn-primary"/>
                        <!-- Cancel button closes the wizard without saving -->
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>

