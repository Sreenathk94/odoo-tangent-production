<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record model="ir.ui.view" id="project_invoice_form">
            <field name="name">project.project.form</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="hr_timesheet.project_invoice_form" />
            <field name="arch" type="xml">
				<xpath expr="//header" position="inside">
					<field name="timesheet_status_id" widget="statusbar" options="{'clickable': '1'}"/>
				</xpath>
				<xpath expr="//field[@name='allow_timesheets']" position="after">
					<field name="allowed_stage_ids" widget="many2many_checkboxes" options="{'no_create': True}"/>
<!--&lt;!&ndash;					<field name="allowed_timesheet_status_ids"  invisible="1"/>&ndash;&gt;-->
<!--					<field name="stage_cost_ids" groups="account.group_account_invoice">-->
<!--						<tree editable="bottom">-->
<!--							<field name="allowed_stage_ids" widget="many2many_checkboxes" invisible="1"/>-->
<!--							<field name="timesheet_status_id" options="{'no_create': True}"/>-->
<!--							<field name="amount" />-->
<!--						</tree>-->
<!--					</field>-->
				</xpath>
            </field>
        </record>
        
        <!--  Tree view  -->
		<record model="ir.ui.view" id="sttl_view_project_view_tree_inherit">
			<field name="name">project.project.tree</field>
			<field name="model">project.project</field>
			<field name="inherit_id" ref="project.view_project" />
			<field name="arch" type="xml">
				<field name="partner_id" position="after">
					<field name="timesheet_count" width="0.5" />
					<field name="timesheet_duration" width="0.5" widget="float_time" />
				</field>
			</field>
		</record>
	</data>
</odoo>
	