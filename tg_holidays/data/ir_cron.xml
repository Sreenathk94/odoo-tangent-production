<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="0">
        <record id="ir_cron_accrue_probation_leave" model="ir.cron">
            <field name="name">Daily Probation Allocation Accrual</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._accrue_daily_probation_leave()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_accrue_indian_probation_leave" model="ir.cron">
            <field name="name">Daily Indian Probation Allocation Accrual</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._accrue_indian_user_probation_leave()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
        <record id="ir_cron_annual_leave_allocation_yearly" model="ir.cron">
            <field name="name">Annual Leave Allocation (Post-Probation)</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._allocate_annual_leave_post_probation()</field>
            <field name="interval_number">12</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="DateTime(DateTime.now().year + 1, 1, 1, 0, 0, 0).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
        <record id="ir_cron_indian_annual_leave_allocation_yearly" model="ir.cron">
            <field name="name">Indian Annual Leave Allocation (Post-Probation)</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._allocate_indian_leave_post_probation()</field>
            <field name="interval_number">12</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="DateTime(DateTime.now().year + 1, 1, 1, 0, 0, 0).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
        <!-- data/cron.xml -->
    <record id="ir_cron_yearly_leave_allocation" model="ir.cron">
        <field name="name">Yearly Leave Allocation</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_type"/>
        <field name="state">code</field>
        <field name="code">model.run_yearly_leave_allocation()</field>
        <field name="interval_type">months</field>
        <field name="interval_number">12</field>
        <field name="numbercall">-1</field>
        <field name="doall">False</field>
        <field name="nextcall" eval="DateTime(DateTime.now().year + 1, 1, 1, 0, 0, 0).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_leave_balance_alert" model="ir.cron">
        <field name="name">Monthly Sick Leave Balance Alert</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_type"/>
        <field name="state">code</field>
        <field name="code">
            model._send_leave_balance_mails(10); model._send_leave_balance_mails(15)
        </field>
        <field name="interval_type">months</field>
        <field name="interval_number">1</field>
        <field name="numbercall">-1</field>
    </record>



    </data>
</odoo>
