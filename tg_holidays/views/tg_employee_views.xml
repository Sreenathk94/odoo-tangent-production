<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="tg_manager_absent_alert_scheduler" model="ir.cron">
        <field name="name">Manager Absent Alert Scheduler</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._entry_manager_absent_alert()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="doall" eval="False"/>
    </record>
    <record id="email_template_manager_absent_alert" model="mail.template">
        <field name="name">Manager Absent Alert</field>
        <field name="model_id" ref="model_hr_employee"/>
        <field name="email_from">{{ ctx['email_from'] }}</field>
        <field name="email_to">{{ ctx['email_to'] }}</field>
        <field name="email_cc">{{ ctx['email_cc'] }}</field>
        <field name="subject">{{ ctx['subject'] }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                Dear <b><t t-out="object.name"/></b>,
                <br></br>
                <br></br>
                This is to inform you that below employees were marked as absent for the following date according to our
                records. If this is accurate, we kindly request you to follow the employees to apply for leave through
                our leave management system.
                <br/>
                <br/>
                <t t-set="emp_ids"  t-value="{{ ctx['emp_ids'] }}"/>
                <ol type="1">
                    <t t-foreach="emp_ids" t-as="emp">
                        <li>
                            <h4><t t-out="emp.name"/></h4>
                            <t t-set="dates"  t-value="{{  object.get_absent_dates(emp) }}"/>
                            <t t-if="dates">
                                <ol type="1">
                                   <t t-foreach="date" t-as="dates">
                                    <li>
                                        <t t-out="{{ date.strftime('%d/%m/%Y') }}"/>
                                    </li>
                                   </t>
                                </ol>
                            </t>
                        </li>
                    </t>
                </ol>
                <br/>
                <br/>
                Please note: This is an automated message, and there is no need to reply to this email.
            </div>
        </field>
        <field name="lang">{{ object.user_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>