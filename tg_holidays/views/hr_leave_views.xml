<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hr_leave_view_tree" model="ir.ui.view">
        <field name="name">hr.leave.tree.inherit.tg_holidays</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='duration_display']" position="after">
                <field name="duration_days_only" string="Duration(Days)"/>
            </xpath>
        </field>
    </record>
    <record id="hr_leave_view_form_inherit_tg_holidays" model="ir.ui.view">
            <field name="name">hr.leave.inherit.inherit.tg_holidays</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="duration_days_only"/>
                </xpath>
                <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            </field>
        </record>
</odoo>