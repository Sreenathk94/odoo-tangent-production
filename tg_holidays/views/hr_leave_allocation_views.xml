<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hr_leave_allocation_view_form" model="ir.ui.view">
        <field name="name">hr.leave.allocation.form.inherit.tg_holidays</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='alloc_right_col']" position="inside">
                <field name="is_cp_leave" invisible="1"/>
                <field name="leave_mode" widget="radio" invisible="not is_cp_leave"/>
                <field name="duration_days_only"/>
            </xpath>
            <xpath expr="//group[@name='alloc_right_col']" position="after">
                <group/>
               <group string="Project Details" invisible="not is_cp_leave">
                <field name="allowed_stage_ids" invisible="1"/>
                <field name="project_id" options="{'no_create': True}" required="is_cp_leave"/>
                <field name="from_date" widget="datetime" required="is_cp_leave"/>
                <field name="to_date" widget="datetime" required="is_cp_leave"/>
                <field name="status_id" domain="[('id', 'in', allowed_stage_ids)]" options="{'no_create': True}" required="is_cp_leave"/>
            </group>
            </xpath>
        </field>
    </record>
    <record id="hr_leave_allocation_view_form_manager" model="ir.ui.view">
        <field name="name">hr.leave.allocation.manager.form.inherit.tg_holidays</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form_manager"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_validate']" position="attributes">
                <attribute name="invisible">state == 'paid'</attribute>
            </xpath>
            <xpath expr="//field[@name='notes']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_refuse']" position="attributes">
                <attribute name="invisible">not can_approve or state not in ('confirm', 'validate', 'paid')</attribute>
            </xpath>
        </field>
    </record>

    <record id="hr_leave_allocation_view_tree" model="ir.ui.view">
        <field name="name">hr.leave.allocation.manager.tree.inherit.tg_holidays</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='duration_display']" position="after">
                <field name="duration_days_only" string="Duration(Days)"/>
            </xpath>
        </field>
    </record>
</odoo>